# ─────────────────────────────────────────────────────────────────────────
#  Inactivity Monitor — environment variables
#  Copy to ".env" (same folder or project root) and fill in the secrets.
#  NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────

# REQUIRED — OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED — Microsoft Teams Workflows inbound webhook URL
TEAMS_WEBHOOK_URL=https://prod-xx.westeurope.logic.azure.com:443/workflows/.../triggers/manual/paths/invoke?...

# OPTIONAL — data source (defaults to the shared tracker workbook with ?download=1)
# SHAREPOINT_FILE_URL=https://globaledulinkuk-my.sharepoint.com/:x:/g/personal/.../...?download=1

# OPTIONAL — OpenRouter model (default: deepseek/deepseek-v3.2-exp)
# OPENROUTER_MODEL=deepseek/deepseek-v3.2-exp
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# OPTIONAL — attribution headers recommended by OpenRouter
# OPENROUTER_SITE_URL=https://your-dashboard.example.com
# OPENROUTER_APP_NAME=Course Tracker Inactivity Monitor

# OPTIONAL — inactivity alarm (fires only when data is stale)
# ENABLE_INACTIVITY_ALARM=true
# INACTIVITY_THRESHOLD_DAYS=2        # alert when data is older than this many days
# CHECK_INTERVAL_MINUTES=60          # how often the alarm re-checks freshness

# OPTIONAL — daily analytics report (always sends at a fixed local time)
# ENABLE_DAILY_REPORT=true
# DAILY_REPORT_TIME=12:45            # 24h HH:MM in the timezone below
# DAILY_REPORT_TIMEZONE=Asia/Kolkata # IANA tz name (e.g. Europe/London, UTC)

# OPTIONAL — networking
# HTTP_TIMEOUT_SECONDS=30
