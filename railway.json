{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r inactivity_monitor/requirements-monitor.txt"
  },
  "deploy": {
    "startCommand": "python -m inactivity_monitor",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
